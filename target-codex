#!/bin/sh
##############################################################################
#
# PROJECT:	PC GEOS
# MODULE:	target-codex
# FILE: 	target-codex
#
# DESCRIPTION:
#	Start the normal target launcher in a shared tmux session with a Swat
#	setup suitable for Codex-driven debugging.
#
#	Usage: target-codex [--watch] [--no-window] [--session <name>]
#	       [--log <file>] [-n]
#
###############################################################################

TARGET_ARGS=
WATCH=0
DIRECT=0
OPEN_WINDOW=1
SESSION=swat-codex
LOGFILE=/tmp/swat-codex.log
while [ "$#" -gt 0 ]; do
  case "$1" in
    -n)
      TARGET_ARGS="-n"
      ;;
    --watch)
      WATCH=1
      ;;
    --direct)
      DIRECT=1
      ;;
    --no-window)
      OPEN_WINDOW=0
      ;;
    --session)
      if [ "$2" = "" ]; then
        echo "Usage: target-codex [--watch] [--no-window] [--session <name>] [--log <file>] [-n]"
        exit 1
      fi
      SESSION=$2
      shift
      ;;
    --log)
      if [ "$2" = "" ]; then
        echo "Usage: target-codex [--watch] [--no-window] [--session <name>] [--log <file>] [-n]"
        exit 1
      fi
      LOGFILE=$2
      shift
      ;;
    *)
      echo "Usage: target-codex [--watch] [--no-window] [--session <name>] [--log <file>] [-n]"
      exit 1
      ;;
  esac
  shift
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if [ "$ROOT_DIR" = "" ]; then
    ROOT_DIR=$(cd "$SCRIPT_DIR/.." && pwd)
fi

attach_session()
{
    echo "Watching tmux session: $SESSION"
    echo "Log file: $LOGFILE"
    if [ "$TERM" = "" ] || [ "$TERM" = "dumb" ]; then
        export TERM=xterm-256color
    fi
    if [ "$TMUX" != "" ]; then
        tmux switch-client -t "$SESSION"
    else
        tmux attach -t "$SESSION"
    fi
}

open_watch_window()
{
    if [ "$OPEN_WINDOW" != "1" ]; then
        return 1
    fi
    if [ "$DISPLAY" = "" ] && [ "$WAYLAND_DISPLAY" = "" ]; then
        return 1
    fi

    if command -v ptyxis >/dev/null 2>&1; then
        ptyxis --new-window --title "Swat Codex" -- sh -c 'tmux attach -t "$1"' sh "$SESSION" >/dev/null 2>&1 &
        return 0
    elif command -v x-terminal-emulator >/dev/null 2>&1; then
        x-terminal-emulator -T "Swat Codex" -e tmux attach -t "$SESSION" >/dev/null 2>&1 &
        return 0
    elif command -v gnome-terminal >/dev/null 2>&1; then
        gnome-terminal --title "Swat Codex" -- tmux attach -t "$SESSION" >/dev/null 2>&1 &
        return 0
    elif command -v konsole >/dev/null 2>&1; then
        konsole --new-tab -p tabtitle="Swat Codex" -e tmux attach -t "$SESSION" >/dev/null 2>&1 &
        return 0
    elif command -v xfce4-terminal >/dev/null 2>&1; then
        xfce4-terminal --title "Swat Codex" -e "tmux attach -t $SESSION" >/dev/null 2>&1 &
        return 0
    elif command -v xterm >/dev/null 2>&1; then
        xterm -T "Swat Codex" -e tmux attach -t "$SESSION" >/dev/null 2>&1 &
        return 0
    fi

    return 1
}

if [ "$DIRECT" != "1" ]; then
    if ! command -v tmux >/dev/null 2>&1; then
        echo "*** target-codex requires tmux."
        exit 1
    fi

    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        tmux new-session -d -s "$SESSION" "$ROOT_DIR/bin/target-codex --direct $TARGET_ARGS"
        tmux pipe-pane -t "$SESSION" -o "cat >> '$LOGFILE'"
    fi

    if [ "$WATCH" != "1" ]; then
        if open_watch_window; then
            echo "Opened Swat viewer window for tmux session: $SESSION"
        else
            echo "No terminal window opened. Attach with: tmux attach -t $SESSION"
        fi
    fi

    attach_session
    exit $?
fi

CODEX_SWAT_HOME=$(mktemp -d "${TMPDIR:-/tmp}/pcgeos-codex-swat.XXXXXX") || exit 1
cleanup()
{
    rm -rf "$CODEX_SWAT_HOME"
}
trap cleanup EXIT HUP INT TERM

cat > "$CODEX_SWAT_HOME/swat.rc" <<EOF
load codex.tcl
EOF

export CODEX_SWAT=1
export HOME="$CODEX_SWAT_HOME"
export TERM=dumb

"$ROOT_DIR/bin/target" $TARGET_ARGS
